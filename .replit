modules = ["python-3.11", "postgresql-16"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python main.py"
waitForPort = 8000

[nix]
channel = "stable-25_05"
packages = ["postgresql"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 80

[userenv]

[userenv.shared]
DB_HOST = "helium"
DB_PORT = "5432"
DB_NAME = "heliumdb"
DB_USER = "postgres"
DB_PASSWORD = "password"
JWT_SECRET = "muttas-liman-super-secret-key-change-in-prod"
